# Copy to `.env`. The only secret the pipeline uses.
#
# Voiceover (optional). vo-sync.ts calls the ElevenLabs TTS API. If this is
# unset, SKIP the narration step — the video renders fine silent, and the
# background-music bed (public/music/soft-explainer-loop.mp3, committed) still
# plays. VO is additive, not required to produce a valid explainer.
ELEVENLABS_API_KEY=
